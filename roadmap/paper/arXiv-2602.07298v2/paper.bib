@misc{yangSyntheticBootstrappedPretraining2025,
  title = {Synthetic Bootstrapped Pretraining},
  author = {Yang, Zitong and Zhang, Aonan and Liu, Hong and Hashimoto, Tatsunori and Cand{\`e}s, Emmanuel and Wang, Chong and Pang, Ruoming},
  year = 2025,
  month = sep,
  number = {arXiv:2509.15248},
  eprint = {2509.15248},
  primaryclass = {cs},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2509.15248},
  urldate = {2025-11-18},
  abstract = {We introduce Synthetic Bootstrapped Pretraining (SBP), a language model (LM) pretraining procedure that first learns a model of relations between documents from the pretraining dataset and then leverages it to synthesize a vast new corpus for joint training. While the standard pretraining teaches LMs to learn causal correlations among tokens within a single document, it is not designed to efficiently model the rich, learnable inter-document correlations that can potentially lead to better performance. We validate SBP by designing a compute-matched pretraining setup and pretrain a 3B-parameter model on up to 1T tokens from scratch. We find SBP consistently improves upon a strong repetition baseline and delivers a significant fraction of performance improvement attainable by an oracle upper bound with access to 20x more unique data. Qualitative analysis reveals that the synthesized documents go beyond mere paraphrases -- SBP first abstracts a core concept from the seed material and then crafts a new narration on top of it. Besides strong empirical performance, SBP admits a natural Bayesian interpretation: the synthesizer implicitly learns to abstract the latent concepts shared between related documents.},
  archiveprefix = {arXiv},
  keywords = {llm,synthetic,to read},
  file = {/Users/qiangzhang/Zotero/storage/T7XCDFE9/Yang et al. - 2025 - Synthetic bootstrapped pretraining.pdf;/Users/qiangzhang/Zotero/storage/AYCA3KUS/2509.html}
}
@inproceedings{bengioCurriculumLearning2009,
  title = {Curriculum Learning},
  booktitle = {Proceedings of the 26th {{Annual International Conference}} on {{Machine Learning}}},
  author = {Bengio, Yoshua and Louradour, J{\'e}r{\^o}me and Collobert, Ronan and Weston, Jason},
  year = 2009,
  month = jun,
  series = {{{ICML}} '09},
  pages = {41--48},
  publisher = {Association for Computing Machinery},
  address = {New York, NY, USA},
  doi = {10.1145/1553374.1553380},
  urldate = {2023-06-19},
  abstract = {Humans and animals learn much better when the examples are not randomly presented but organized in a meaningful order which illustrates gradually more concepts, and gradually more complex ones. Here, we formalize such training strategies in the context of machine learning, and call them "curriculum learning". In the context of recent research studying the difficulty of training in the presence of non-convex training criteria (for deep deterministic and stochastic neural networks), we explore curriculum learning in various set-ups. The experiments show that significant improvements in generalization can be achieved. We hypothesize that curriculum learning has both an effect on the speed of convergence of the training process to a minimum and, in the case of non-convex criteria, on the quality of the local minima obtained: curriculum learning can be seen as a particular form of continuation method (a general strategy for global optimization of non-convex functions).},
  isbn = {978-1-60558-516-1}
}

@misc{duUnlockingContinualLearning2024,
  title = {Unlocking {{Continual Learning Abilities}} in {{Language Models}}},
  author = {Du, Wenyu and Cheng, Shuang and Luo, Tongxu and Qiu, Zihan and Huang, Zeyu and Cheung, Ka Chun and Cheng, Reynold and Fu, Jie},
  year = 2024,
  month = jun,
  number = {arXiv:2406.17245},
  eprint = {2406.17245},
  primaryclass = {cs},
  publisher = {arXiv},
  urldate = {2024-06-27},
  abstract = {Language models (LMs) exhibit impressive performance and generalization capabilities. However, LMs struggle with the persistent challenge of catastrophic forgetting, which undermines their long-term sustainability in continual learning (CL). Existing approaches usually address the issue by incorporating old task data or task-wise inductive bias into LMs. However, old data and accurate task information are often unavailable or costly to collect, hindering the availability of current CL approaches for LMs. To address this limitation, we introduce \$\textbackslash textbf\textbraceleft MIGU\textbraceright\$ (\$\textbackslash textbf\textbraceleft M\textbraceright\$agn\$\textbackslash textbf\textbraceleft I\textbraceright\$tude-based \$\textbackslash textbf\textbraceleft G\textbraceright\$radient \$\textbackslash textbf\textbraceleft U\textbraceright\$pdating for continual learning), a rehearsal-free and task-label-free method that only updates the model parameters with large magnitudes of output in LMs' linear layers. MIGU is based on our observation that the L1-normalized magnitude distribution of the output in LMs' linear layers is different when the LM models deal with different task data. By imposing this simple constraint on the gradient update process, we can leverage the inherent behaviors of LMs, thereby unlocking their innate CL abilities. Our experiments demonstrate that MIGU is universally applicable to all three LM architectures (T5, RoBERTa, and Llama2), delivering state-of-the-art or on-par performance across continual finetuning and continual pre-training settings on four CL benchmarks. For example, MIGU brings a 15.2\% average accuracy improvement over conventional parameter-efficient finetuning baselines in a 15-task CL benchmark. MIGU can also seamlessly integrate with all three existing CL types to further enhance performance. Code is available at \textbackslash href\textbraceleft https://github.com/wenyudu/MIGU\textbraceright\textbraceleft this https URL\textbraceright.},
  archiveprefix = {arXiv},
  keywords = {continual learning,read},
  file = {/Users/qiangzhang/Zotero/storage/6MEB2VM2/Du et al. - 2024 - Unlocking Continual Learning Abilities in Language.pdf;/Users/qiangzhang/Zotero/storage/VJCVVL26/2406.html}
}
